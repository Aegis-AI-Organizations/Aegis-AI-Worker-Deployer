{
  "scan_id": "smoke-sqli-001",
  "preferred_endpoint_workload": "vulnerable-webapp",
  "topology": {
    "services": [
      {
        "id": "webapp-1",
        "name": "vulnerable-webapp",
        "image": "ghcr.io/aegis-ai-organizations/vuln-app:latest",
        "depends_on": ["postgres"],
        "wait_for": ["postgres:5432"],
        "working_dir": "/app",
        "config_files": [
          {
            "path": "/app/config.yml",
            "content": "feature_insecure_search: true\nexternal_api_url: https://payments.example.test/api/v1\n"
          }
        ],
        "empty_dirs": [
          {
            "name": "uploads",
            "mount_path": "/app/uploads"
          }
        ],
        "resources": {
          "requests": {"cpu": "50m", "memory": "64Mi"},
          "limits": {"cpu": "250m", "memory": "256Mi"}
        },
        "security_context": {
          "runAsUser": 1000,
          "allowPrivilegeEscalation": false
        },
        "ports": [
          {
            "name": "http",
            "port": 80,
            "target_port": 5000,
            "container_port": 5000,
            "protocol": "TCP"
          }
        ],
        "env": {
          "DATABASE_URL": "postgresql://aegis:aegis@postgres:5432/aegis_demo",
          "POSTGRES_HOST": "postgres",
          "POSTGRES_PORT": "5432",
          "POSTGRES_DB": "aegis_demo",
          "POSTGRES_USER": "aegis",
          "POSTGRES_PASSWORD": "aegis",
          "EXTERNAL_API_URL": "https://payments.example.test/api/v1",
          "FEATURE_INSECURE_SEARCH": "true"
        },
        "liveness_probe": {
          "httpGet": {
            "path": "/health",
            "port": 5000
          },
          "initialDelaySeconds": 5,
          "periodSeconds": 10
        }
      }
    ],
    "deployments": [
      {
        "id": "db-1",
        "name": "postgres",
        "image": "postgres:16-alpine",
        "stateful": true,
        "required": true,
        "service": {
          "headless": true,
          "aliases": ["db"]
        },
        "ports": [
          {
            "name": "postgres",
            "port": 5432,
            "target_port": 5432,
            "container_port": 5432,
            "protocol": "TCP"
          }
        ],
        "env": {
          "POSTGRES_DB": "aegis_demo",
          "POSTGRES_USER": "aegis",
          "POSTGRES_PASSWORD": "aegis"
        }
      }
    ]
  }
}
